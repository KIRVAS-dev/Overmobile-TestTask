# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

.utmp/
/Overmobile/[Ll]ibrary/
/Overmobile/ios/
/Overmobile/[Tt]emp/
/Overmobile/[Oo]bj/
/Overmobile/[Bb]uild/
/Overmobile/[Bb]uilds/
/Overmobile/[Ll]ogs/
/Overmobile/[Uu]ser[Ss]ettings/
/Overmobile/[Rr]ecordings
*.log

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/Overmobile/[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/Overmobile/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/Overmobile/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
/Overmobile/.vs/
/Overmobile/.idea
/Overmobile/.git

# Gradle cache directory
/Overmobile/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/Overmobile/ExportedObj/
/Overmobile/.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta
/Overmobile/[Aa]ssets/[Ss]treaming[Aa]ssets/build_inf*

# Crashlytics generated file
/Overmobile/crashlytics-build.properties

# Packed Addressables
/Overmobile//[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/Overmobile//[Aa]ssets/[Ss]treamingAssets/aa.meta
/Overmobile//[Aa]ssets/[Ss]treamingAssets/aa/*

# Exceptions
!*.dll
!*.obj

# MaсOS system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
ehthumbs.db
Thumbs.db

# CI
CI/Temp/
CI/Base/__pycache__/
Overmobile/Assets/SceneDependencyCache

# Cursor
.cursor/

# VSCode
.vscode/
Overmobile/Overmobile.slnx

#NuGetForUnity
Overmobile/[Pp]ackages/nuget-packages/InstalledPackages*

#Build cache
Overmobile/.utmp

# FMOD
# Never ignore DLLs in the FMOD subfolder.
!Overmobile/[Aa]ssets/Plugins/FMOD/**/lib/*

# Don't ignore images and gizmos used by FMOD in the Unity Editor.
!Overmobile/[Aa]ssets/Gizmos/FMOD/*
!Overmobile/[Aa]ssets/Editor Default Resources/FMOD/*

# Ignore the Cache folder since it is updated locally.
Overmobile/[Aa]ssets/Plugins/FMOD/Cache/*

# Ignore bank files in the StreamingAssets folder.
Overmobile/[Aa]ssets/StreamingAssets/**/*.bank
Overmobile/[Aa]ssets/StreamingAssets/**/*.bank.meta

# If the source bank files are kept outside of the StreamingAssets folder then these can be ignored.
# Log files can be ignored.
Overmobile/fmod_editor.log

FMOD/.*